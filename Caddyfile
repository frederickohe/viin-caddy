# Viin platform — single Caddy entrypoint
# Container DNS names must match container_name in each compose stack.

api.viin.app {
	reverse_proxy viin_backend:8000 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}

task.viin.app {
	reverse_proxy viin_web:80 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}
