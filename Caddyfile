# Viin platform — single Caddy entrypoint
# Container DNS names must match container_name in each compose stack.

api.useviin.com {
	reverse_proxy viin_backend:8000 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}

useviin.com, www.useviin.com {
	reverse_proxy viin_web:80 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}

chatwoot.useviin.com {
	reverse_proxy chatwoot_rails:3000 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}

postiz.useviin.com {
	reverse_proxy postiz:5000 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 50MB
	}
}

rag.useviin.com {
	reverse_proxy greenbrain_rag_api:8088 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}

	request_body {
		max_size 10MB
	}
}

portainer.useviin.com {
	reverse_proxy https://viin_portainer:9443 {
		transport http {
			tls_insecure_skip_verify
		}
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
	}
}
